/* ================= 专业测量视觉体系 ================= */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background: #F6F8FB;
  color: #5E6678;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -webkit-font-smoothing: subpixel-antialiased;
}

/* ========== 色彩系统 ========== */
.color-primary-light { color: #EAF0FF; }
.color-primary-main { color: #2454FF; }
.color-accent { color: #12B8A6; }
.color-text-title { color: #182033; }
.color-text-body { color: #5E6678; }
.color-text-muted { color: #9AA4B5; }

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, #2454FF 0%, #12B8A6 100%);
}

.gradient-bg-light {
  background: linear-gradient(135deg, #EEF4FF 0%, #E9FBF7 100%);
}

/* 基础卡片 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 18rpx 46rpx rgba(18, 28, 45, 0.08);
  border: 1rpx solid rgba(212, 220, 232, 0.9);
  padding: 40rpx;
  margin: 24rpx 32rpx;
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #2454FF 0%, #12B8A6 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 18rpx;
  padding: 28rpx 64rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0;
  box-shadow: 0 14rpx 30rpx rgba(36, 84, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 8rpx 20rpx rgba(36, 84, 255, 0.18);
}

/* 次要按钮 */
.btn-secondary {
  background: #FFFFFF;
  color: #2454FF;
  border: 1rpx solid #D7DEEA;
  border-radius: 18rpx;
  padding: 26rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(18, 28, 45, 0.05);
  transition: all 0.2s ease;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  transform: translateY(2rpx) scale(0.98);
}

/* 文字样式 */
.text-gradient {
  background: linear-gradient(135deg, #2454FF 0%, #12B8A6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-white {
  color: #FFFFFF;
}

.text-gray {
  color: #9AA4B5;
}

.text-title {
  color: #182033;
  font-weight: 700;
}

.text-muted {
  color: #9AA4B5;
}

.text-center {
  text-align: center;
}

/* flex 布局 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

/* 间距 */
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mt-60 { margin-top: 60rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-40 { margin-bottom: 40rpx; }
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }

/* 动画 */
@keyframes softRise {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

@keyframes rippleExpand {
  0% { transform: scale(0.3); opacity: 0.8; border-width: 4rpx; }
  100% { transform: scale(1.2); opacity: 0; border-width: 1rpx; }
}

.animate-softRise {
  animation: softRise 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}

.animate-fadeInUp {
  animation: fadeInUp 0.6s ease forwards;
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-float {
  animation: float 3s ease-in-out infinite;
}
